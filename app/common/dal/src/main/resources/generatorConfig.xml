<!DOCTYPE generatorConfiguration PUBLIC
        "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "https://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <context id="alipay" targetRuntime="MyBatis3">

        <!-- JDBC connection -->
        <jdbcConnection
                driverClass="org.postgresql.Driver"
                connectionURL="jdbc:postgresql://localhost:5432/merchant"
                userId="adam"
                password="1234" />

        <!-- Java Model (DO) generation -->
        <javaModelGenerator
                targetPackage="com.alipay.merchant.common.dal.auto.dataobject"
                targetProject="src/main/java"/>

        <!-- Mapper XML generation -->
        <sqlMapGenerator
                targetPackage="sqlmap.imerchant.auto"
                targetProject="src/main/resources"/>

        <!-- Mapper interface generation -->
        <javaClientGenerator
                type="XMLMAPPER"
                targetPackage="com.alipay.merchant.common.dal.auto.daointerface"
                targetProject="src/main/java"/>

        <!-- Table(s) to generate -->
        <table tableName="merchant_info" domainObjectName="MerchantInfoDO" />

    </context>
</generatorConfiguration>
